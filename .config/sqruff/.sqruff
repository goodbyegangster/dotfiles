[sqruff]
dialect = snowflake
templater = placeholder

max_line_length = 120

[sqruff:templater:placeholder]
param_regex = <%\s*(?P<param_name>[A-Za-z_][A-Za-z0-9_]*)\s*%>

[sqruff:indentation]
indent_unit = space
tab_space_size = 4
indented_joins = True
allow_implicit_indents = True

[sqruff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqruff:rules:capitalisation.identifiers]
capitalisation_policy = upper

[sqruff:rules:capitalisation.functions]
capitalisation_policy = lower

[sqruff:rules:capitalisation.literals]
capitalisation_policy = lower

[sqruff:rules:capitalisation.type]
capitalisation_policy = lower
