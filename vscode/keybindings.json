// Place your key bindings in this file to override the defaultsauto[]
[
  /*******************************************
  / terminal
  ********************************************/
  // [Ctrl + O] terminal に focus がないとき terminal に focus を移す
  {
    "key": "ctrl+o",
    "command": "workbench.action.terminal.focus",
    "when": "!terminalFocus"
  },
  // [Ctrl + O] terminal に focus　があるとき editor に focus を移す
  {
    "key": "ctrl+o",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "panelFocus"
  },
  // [Ctrl + Shift + J] Terminal を次の tab に移動する
  {
    "key": "ctrl+shift+j",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus"
  },
  // [Ctrl + Shift + L] Terminal を次の panel view に移動する
  {
    "key": "ctrl+shift+l",
    "command": "workbench.action.nextPanelView",
    "when": "panelFocus"
  },
  // [Ctrl + Shift + K] Terminal を前の panel view に移動する
  {
    "key": "ctrl+shift+k",
    "command": "workbench.action.previousPanelView",
    "when": "panelFocus"
  },
  /*******************************************
  / sidebar view
  ********************************************/
  // [Ctrl + Shift + ]] sideBar view を次に移動する
  {
    "key": "ctrl+shift+]",
    "command": "workbench.action.nextSideBarView",
    "when": "sideBarFocus"
  },
  // [Ctrl + Shift + [] sideBar view を前に移動する
  {
    "key": "ctrl+shift+[",
    "command": "workbench.action.previousSideBarView",
    "when": "sideBarFocus"
  },
  /*******************************************
  / secondary sidebar view
  ********************************************/
  // [Ctrl + Shift + U] claude の chat panel に移動する
  {
    "key": "ctrl+shift+u",
    "command": "claudeVSCodeSidebarSecondary.focus"
  },
  // [Ctrl + Shift + Y] chatgpt の chat panel に移動する
  {
    "key": "ctrl+shift+y",
    "command": "chatgpt.sidebarSecondaryView.focus"
  },
  /*******************************************
  / other
  ********************************************/
  // [Ctrl + Shift + C] tasks で定義した CopyPathWithLineNumber を実行する
  {
    "key": "ctrl+shift+c",
    "command": "workbench.action.tasks.runTask",
    "args": "CopyPathWithLineNumber",
    "when": "editorTextFocus"
  },
  // [Ctrl + Shift + R] Reload Window を実行する
  {
    "key": "ctrl+shift+r",
    "command": "workbench.action.reloadWindow"
  },
  // [Ctrl + Shift + S] Sort Lines を実行する
  {
    "key": "ctrl+shift+s",
    "command": "editor.action.sortLinesAscending",
    "when": "editorTextFocus"
  },
]