{
  /**************************************************
  / workbench
  ***************************************************/
  "workbench.colorTheme": "Dark Modern",
  "workbench.colorCustomizations": {
    "editorWhitespace.foreground": "#4d4c4c",
  },
  "workbench.editor.enablePreview": true,
  "workbench.editorLargeFileConfirmation": 3072,
  "workbench.startupEditor": "none",
  /**************************************************
  / terminal
  ***************************************************/
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    },
    "Command Prompt": {
      "path": [
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe"
      ],
      "args": [],
      "icon": "terminal-cmd"
    },
    "Git Bash": {
      "source": "Git Bash"
    },
    "Ubuntu (WSL)": {
      "path": "C:\\windows\\System32\\wsl.exe",
      "args": [
        "-d",
        "Ubuntu"
      ]
    }
  },
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.scrollback": 5000,
  /**************************************************
  / editor
  ***************************************************/
  // NOTE: https://stackoverflow.com/questions/54173462/how-to-turn-off-or-on-sounds-from-visual-studio-code
  "editor.accessibilitySupport": "off",
  "editor.copyWithSyntaxHighlighting": false,
  "editor.formatOnSave": false,
  "editor.guides.indentation": true,
  "editor.renderWhitespace": "boundary",
  // https://code.visualstudio.com/docs/editing/intellisense#_snippets-in-suggestions
  "editor.snippetSuggestions": "top",
  "editor.unicodeHighlight.nonBasicASCII": false,
  /**************************************************
  / explorer
  ***************************************************/
  "explorer.fileNesting.enabled": false,
  /**************************************************
  / remote
  ***************************************************/
  "remote.autoForwardPortsSource": "hybrid",
  /**************************************************
  / files
  ***************************************************/
  "files.associations": {
    // dbt - don't format models in `target/` dir
    "**/target/**": "",
    // html
    "*.html.j2": "jinja-html",
    // ini
    "**/pnpm/rc": "ini",
    ".sqruff": "ini",
    // jinja
    "*.j2": "jinja",
    // JSON
    "*.json.default": "json",
    // JSONC
    "**/textlint/config.json": "jsonc",
    // Markdown
    "**/skills/*/SKILL.md": "markdown",
    // Python
    "*.py.template": "python",
    // sql
    "*.sql": "sql",
    "*.sql.j2": "jinja-sql",
    // templ
    "*.templ": "templ",
    // toml
    "*.toml.template": "toml",
    // YAML
    "*.yml.default": "yaml",
    "*.yaml.default": "yaml",
    "*.yml.template": "yaml",
    "*.yaml.template": "yaml",
  },
  "files.eol": "\n",
  /**************************************************
  / extension
  **************************************************/
  /**************************************************
  / AWS Toolkit
  **************************************************/
  // "aws.codeWhisperer.importRecommendation": false,
  // "aws.codeWhisperer.includeSuggestionsWithCodeReferences": false,
  "aws.telemetry": false,
  /**************************************************
  / dbt Power User
  **************************************************/
  "dbt.queryLimit": 5,
  /**************************************************
  / C
  **************************************************/
  "[c]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "C_Cpp.clang_format_fallbackStyle": "Google",
  "C_Cpp.codeAnalysis.runAutomatically": true,
  "C_Cpp.codeAnalysis.clangTidy.enabled": true,
  /**************************************************
  / ChatGPT / Codex
  ***************************************************/
  // https://developers.openai.com/codex/ide/settings#settings-reference
  "chatgpt.commentCodeLensEnabled": false,
  /**************************************************
  / cSpell
  ***************************************************/
  "cSpell.enabled": true,
  "cSpell.languageSettings": [
    {
      "languageId": "templ",
      "includeRegExpList": [
        "Go"
      ]
    }
  ],
  "cSpell.customDictionaries": {
    "aws": {
      "name": "aws",
      "path": "~/dotfiles/.config/cspell/aws.txt",
      "addWords": true,
    },
    "bash": {
      "name": "bash",
      "path": "~/dotfiles/.config/cspell/bash.txt",
      "addWords": true,
    },
    "cloud-init": {
      "name": "cloud-init",
      "path": "~/dotfiles/.config/cspell/cloud-init.txt",
      "addWords": true,
    },
    "common": {
      "name": "common",
      "path": "~/dotfiles/.config/cspell/common.txt",
      "addWords": true,
    },
    "dbt": {
      "name": "dbt",
      "path": "~/dotfiles/.config/cspell/dbt.txt",
      "addWords": true,
    },
    "go": {
      "name": "go",
      "path": "~/dotfiles/.config/cspell/go.txt",
      "addWords": true,
    },
    "javascript": {
      "name": "javascript",
      "path": "~/dotfiles/.config/cspell/javascript.txt",
      "addWords": true,
    },
    "opensearch": {
      "name": "opensearch",
      "path": "~/dotfiles/.config/cspell/opensearch.txt",
      "addWords": true,
    },
    "private": {
      "name": "private",
      "path": "~/dotfiles/.config/cspell/private.txt",
      "addWords": true,
    },
    "projects": {
      "name": "projects",
      "path": "~/dotfiles/.config/cspell/projects.txt",
      "addWords": true,
    },
    "python": {
      "name": "python",
      "path": "~/dotfiles/.config/cspell/python.txt",
      "addWords": true,
    },
    "python-jinja": {
      "name": "python-jinja",
      "path": "~/dotfiles/.config/cspell/python-jinja.txt",
      "addWords": true,
    },
    "powershell": {
      "name": "powershell",
      "path": "~/dotfiles/.config/cspell/powershell.txt",
      "addWords": true,
    },
    "rust": {
      "name": "rust",
      "path": "~/dotfiles/.config/cspell/rust.txt",
      "addWords": true,
    },
    "snowflake": {
      "name": "snowflake",
      "path": "~/dotfiles/.config/cspell/snowflake.txt",
      "addWords": true,
    },
    "sql": {
      "name": "sql",
      "path": "~/dotfiles/.config/cspell/sql.txt",
      "addWords": true,
    },
    "custom": true,
    "internal-terms": true,
  },
  /**************************************************
  / CSS / SCSS
  ***************************************************/
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    }
  },
  "[scss]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    }
  },
  "css.validate": false,
  "scss.validate": false,
  "less.validate": false,
  // Tailwind CSS
  "tailwindCSS.includeLanguages": {
    "templ": "html"
  },
  /**************************************************
  / Dataform
  ***************************************************/
  "vscode-dataform-tools.bigqueryAuthenticationCheck": false,
  "vscode-dataform-tools.showCompiledQueryInVerticalSplitOnSave": false,
  "vscode-dataform-tools.compileAndDryRunBeforeFormatting": false,
  /**************************************************
  / Docker
  ***************************************************/
  // hadolint
  "hadolint.hadolintPath": "hadolint",
  "hadolint.cliOptions": [],
  "hadolint.maxNumberOfProblems": 100,
  "hadolint.outputLevel": "warning",
  // Docker compose
  "[Compose]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "ms-azuretools.vscode-docker",
    "editor.formatOnSave": true,
  },
  /**************************************************
  / Emmet
  ***************************************************/
  // https://code.visualstudio.com/docs/languages/emmet
  "emmet.includeLanguages": {
    "typescriptreact": "html"
  },
  "emmet.triggerExpansionOnTab": true,
  /**************************************************
  / Git
  ***************************************************/
  "git.blame.editorDecoration.enabled": false,
  /**************************************************
  / GitHub
  ***************************************************/
  "editor.inlineSuggest.enabled": false, // https://docs.github.com/en/copilot/how-tos/configure-personal-settings/configure-in-ide#enabling-or-disabling-github-copilot-inline-suggestions
  /**************************************************
  / Go
  ***************************************************/
  "[go]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": false,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "golang.go",
  },
  "go.toolsManagement.checkForUpdates": "proxy", // https://github.com/golang/vscode-go/blob/master/docs/settings.md#gotoolsmanagementcheckforupdates
  "gopls": {
    "ui.semanticTokens": false // https://github.com/golang/vscode-go/blob/master/docs/settings.md#uisemantictokens
  },
  // https://templ.guide/developer-tools/ide-support#visual-studio-code
  "[templ]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": false,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "a-h.templ",
  },
  /**************************************************
  / HTML
  ***************************************************/
  "[html]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit"
    },
  },
  "html.customData": [
    // htmx: https://github.com/otovo/htmx-tags/blob/main/html.htmx-data.json
    ".config/html/html.htmx-data.json"
  ],
  "html.format.extraLiners": "",
  "editor.linkedEditing": true, // https://code.visualstudio.com/docs/languages/html#_auto-update-tags
  /**************************************************
  / HTTP
  ***************************************************/
  "[http]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  /**************************************************
  / JavaScript
  ***************************************************/
  "[javascript]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit",
      "source.organizeImports.biome": "explicit"
    },
  },
  "javascript.suggestionActions.enabled": false,
  /**************************************************
  / JSON
  ***************************************************/
  "[json]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  // JSON with Comments
  "[jsonc]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "json.schemas": [
    // Tolerate trailing commas in jsonc format
    // https://github.com/microsoft/vscode/issues/102061
    {
      "fileMatch": [
        "*.json"
      ],
      "schema": {
        "allowTrailingCommas": true
      },
    }
  ],
  "json.schemaDownload.trustedDomains": {
    "https://biomejs.dev": true,
    "https://raw.githubusercontent.com": true,
  },
  /**************************************************
  / Makefile
  ***************************************************/
  "[makefile]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": false,
  },
  "makefile.configureOnOpen": false,
  "makefile.launchConfigurations": [],
  "makefile.makePath": "/usr/bin/make",
  /**************************************************
  / Markdown
  ***************************************************/
  "[markdown]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "davidanson.vscode-markdownlint",
    "editor.formatOnSave": true,
    "files.trimTrailingWhitespace": false,
  },
  "markdownlint.configFile": "~/.markdownlint-cli2.jsonc", // 実際は .config/markdownlint-cli2/markdownlint-cli2.jsonc で管理
  // Markdown All in One の toc 作成ルール
  "markdown.extension.toc.levels": "2..3",
  "markdown.extension.toc.omittedFromToc": {},
  "markdown-pdf.executablePath": "/usr/bin/chromium-browser",
  /**************************************************
  / PowerShell
  / PowerShell 向けの設定は vscode/settings-windows/settings.json で管理されている
  / 本ファイル記載のものは WSL 上で利用・開発する場合の設定
  ***************************************************/
  // https://learn.microsoft.com/en-us/powershell/scripting/dev-cross-plat/vscode/using-vscode#adding-your-own-powershell-paths-to-the-session-menu
  "powershell.powerShellAdditionalExePaths": {
    "Mise PowerShell": "~/.local/share/mise/shims/pwsh"
  },
  "powershell.powerShellDefaultVersion": "Mise PowerShell",
  // https://learn.microsoft.com/ja-jp/powershell/utility-modules/psscriptanalyzer/using-scriptanalyzer?view=ps-modules#using-custom-rules-in-visual-studio-code-vs-code
  "powershell.scriptAnalysis.settingsPath": "~/dotfiles/pwsh/ScriptAnalyzerSettings.psd1",
  /**************************************************
  / Python
  ***************************************************/
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
    }
  },
  "python.interpreter.infoVisibility": "always",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.typeCheckingMode": "standard",
  "python.languageServer": "Pylance",
  "ruff.lineLength": 100,
  "ruff.enable": true,
  "ruff.lint.select": [
    "ALL"
  ],
  "ruff.lint.ignore": [
    "ANN401", // Dynamically typed expressions (typing.Any) are disallowed
    "BLE001", // Do not catch blind exception: `Exception`
    "COM812", // Trailing comma missing
    "D100", // Missing docstring in public module
    "D104", // Missing docstring in public module
    "D107", // Missing docstring in `__init__`
    "D202", // No blank lines allowed after function docstring
    "D400", // First line should end with a period
    "D401", // First line should end with a period
    "D403", // First word of the docstring should be capitalized
    "D415", // First line should end with a period
    "EM101", // Exception must not use a string literal, assign to variable first
    "ERA001", // Found commented-out code
    "RUF001", // Checks for ambiguous Unicode characters in strings
    "RUF002", // Checks for ambiguous Unicode characters in docstring
    "RUF003", // Checks for ambiguous Unicode characters in comments
    "T201", // `print` found
    "TC001", // Move application import "" into a type-checking block
    "TC002", // Move application import "" into a type-checking block
    "TC003", // Move application import "" into a type-checking block
    "TRY003", // Avoid specifying long messages outside the exception class
  ],
  /**************************************************
  / Shell
  ***************************************************/
  "[shellscript]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": false,
    "editor.defaultFormatter": "foxundermoon.shell-format",
    "editor.formatOnSave": true,
  },
  // shellcheck
  "shellcheck.enable": true,
  "shellcheck.enableQuickFix": true,
  "shellcheck.run": "onSave",
  "shellcheck.executablePath": "", // Priority: user defined > bundled shellcheck binary > "shellcheck"
  "shellcheck.exclude": [],
  "shellcheck.customArgs": [
    "-x"
  ],
  "shellcheck.ignorePatterns": {
    "**/.bashrc": true,
    "**/.profile": true,
  },
  /**************************************************
  / SQL
  ***************************************************/
  "[sql]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "Quary.sqruff",
  },
  // sqlfluff
  // "sqlfluff.executablePath": "${workspaceFolder}/.venv/bin/sqlfluff",
  // "sqlfluff.config": "~/dotfiles/.config/.sqlfluff/.sqlfluff",
  // "sqlfluff.linter.run": "onSave",
  // sqruff
  "sqruff.executablePath": "~/.local/share/mise/shims/sqruff",
  /**************************************************
  / Terraform
  ***************************************************/
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file"
  },
  "[terraform-vars]": {
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file"
  },
  /**************************************************
  / TOML
  ***************************************************/
  "[toml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
  },
  /**************************************************
  / TypeScript
  ***************************************************/
  "[typescript]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit",
      "source.organizeImports.biome": "explicit"
    },
  },
  "typescript.inlayHints.parameterNames.enabled": "all",
  "[typescriptreact]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "explicit",
      "source.organizeImports.biome": "explicit"
    },
  },
  "jsdoc-generator.includeTypes": false,
  /**************************************************
  / YAML
  ***************************************************/
  "[yaml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.formatOnSave": true,
  },
  "yaml.format.enable": true,
  "yaml.format.printWidth": 999, // 配列要素名が一定の長さを超えると壊れてしまうので対応 https://github.com/redhat-developer/vscode-yaml/issues/968#issuecomment-1748610455
  "yaml.maxItemsComputed": 10000,
  "yaml.schemas": {
    // dbt
    // https://github.com/dbt-labs/dbt-jsonschema
    "https://raw.githubusercontent.com/dbt-labs/dbt-jsonschema/main/schemas/latest/dbt_yml_files-latest.json": [
      "/**/models/**/*.yml",
      "/**/snapshots/**/*.yml",
    ],
    "https://raw.githubusercontent.com/dbt-labs/dbt-jsonschema/main/schemas/latest/dbt_project-latest.json": [
      "dbt_project.yml",
    ],
    "https://raw.githubusercontent.com/dbt-labs/dbt-jsonschema/main/schemas/latest/selectors-latest.json": [
      "selectors.yml",
    ],
    "https://raw.githubusercontent.com/dbt-labs/dbt-jsonschema/main/schemas/latest/packages-latest.json": [
      "packages.yml",
    ],
  },
  "yaml.customTags": [
    // Cloud Formation
    // https://github.com/redhat-developer/vscode-yaml/issues/669
    "!Base64 scalar",
    "!Contains sequence",
    "!Cidr scalar",
    "!And sequence",
    "!Equals sequence",
    "!If sequence",
    "!Not sequence",
    "!Or sequence",
    "!Condition scalar",
    "!FindInMap sequence",
    "!GetAtt sequence",
    "!GetAtt scalar",
    "!GetAZs scalar",
    "!ImportValue scalar",
    "!Join sequence",
    "!Select sequence",
    "!Split sequence",
    "!Sub scalar",
    "!Transform mapping",
    "!Ref scalar",
  ],
  "redhat.telemetry.enabled": false,
  /**************************************************
  / launch.json
  ***************************************************/
  "launch": {
    "version": "0.2.0",
    "configurations": [
      // Bash
      // https://bashdb.sourceforge.net/bashdb-man.html
      {
        "name": "Remote: Bash: bashdb",
        "type": "bashdb",
        "request": "launch",
        "program": "${file}",
        "cwd": "${fileDirname}",
        "args": [],
        "showDebugOutput": true,
        "terminalKind": "integrated", // https://github.com/rogalmic/vscode-bash-debug/blob/master/README.md#limitations-and-known-problems
        "trace": false,
        "presentation": {
          "hidden": false,
          "group": "Remote",
          "order": 1
        }
      },
      // Go
      {
        "name": "Remote: Go: Launch Package",
        "type": "go",
        "request": "launch",
        "mode": "auto",
        "program": "${fileDirname}",
        "args": [],
        "env": {},
        "showLog": true,
        "presentation": {
          "hidden": false,
          "group": "Remote",
          "order": 2
        }
      }
    ]
  }
}
